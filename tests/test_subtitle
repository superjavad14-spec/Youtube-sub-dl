import os
import tempfile

import pyzipper
import pytest
from unittest.mock import patch, MagicMock

from scripts.zip_protector import create_encrypted_zip
from scripts.translator import translate_srt


def test_encrypted_zip_creation_and_access():
    """تست ساخت ZIP رمزگذاری شده و عدم دسترسی بدون رمز"""
    with tempfile.TemporaryDirectory() as tmpdir:
        file_path = os.path.join(tmpdir, 'test.srt')
        with open(file_path, 'w') as f:
            f.write("1\n00:00:01,000 --> 00:00:02,000\nHello\n\n")

        zip_path = os.path.join(tmpdir, 'test.zip')
        password = "p@ssw0rd!"
        create_encrypted_zip(file_path, zip_path, password)

        assert os.path.exists(zip_path)

        # تلاش برای خواندن بدون رمز باید خطا دهد
        with pytest.raises(RuntimeError):
            with pyzipper.AESZipFile(zip_path, 'r') as zf:
                zf.read('test.srt')

        # با رمز صحیح باید خوانده شود
        with pyzipper.AESZipFile(zip_path, 'r') as zf:
            zf.setpassword(password.encode())
            content = zf.read('test.srt').decode('utf-8')
        assert "Hello" in content


@patch('scripts.translator.GoogleTranslator')
def test_translate_srt_mock(mock_translator):
    """تست ترجمه با ماکت GoogleTranslator"""
    instance = MagicMock()
    instance.translate = MagicMock(
        side_effect=lambda text: "سلام" if text.strip() else text
    )
    mock_translator.return_value = instance

    input_content = "1\n00:00:01,000 --> 00:00:02,000\nHello\n\n"
    with tempfile.TemporaryDirectory() as tmpdir:
        input_path = os.path.join(tmpdir, 'input.srt')
        output_path = os.path.join(tmpdir, 'output.srt')
        with open(input_path, 'w', encoding='utf-8') as f:
            f.write(input_content)

        translate_srt(input_path, output_path)

        with open(output_path, 'r', encoding='utf-8') as f:
            result = f.read()

        assert "سلام" in result
        assert "00:00:01,000 --> 00:00:02,000" in result


